# Copy this file to /opt/huafu-crm-suite/config/huafu-crm.env if the server
# does not already have one. The deploy script preserves the real env file.
CRM_DB_URL=jdbc:postgresql://127.0.0.1:5432/huafu_crm
CRM_DB_USERNAME=huafu
CRM_DB_PASSWORD=please_change_me
CRM_JWT_SECRET=please_change_me_to_a_long_random_secret
CRM_GATEWAY_ADDRESS=0.0.0.0
CRM_SERVICE_ADDRESS=127.0.0.1
LD_LIBRARY_PATH=/opt/huafu-crm-suite/backend/lib
